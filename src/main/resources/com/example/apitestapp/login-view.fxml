<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="login-root" stylesheets="@styles/styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.apitestapp.controllers.LoginController">
    <children>
        <VBox maxWidth="520.0" spacing="18.0" styleClass="login-card">
            <padding>
                <Insets bottom="28" left="28" right="28" top="28" />
            </padding>
            <children>
                <Label styleClass="login-title" text="ĐĂNG NHẬP" />

                <VBox spacing="8.0">
                    <Label styleClass="login-label" text="Tên đăng nhập:" />
                    <TextField fx:id="usernameField" promptText="Nhập tên đăng nhập" styleClass="login-input" />
                </VBox>

                <VBox spacing="8.0">
                    <Label styleClass="login-label" text="Mật khẩu:" />
                    <PasswordField fx:id="passwordField" promptText="Nhập mật khẩu" styleClass="login-input" />
                </VBox>

                <VBox spacing="8.0">
                    <Label styleClass="login-label" text="Vai trò:" />
                    <ComboBox fx:id="roleComboBox" maxWidth="1.7976931348623157E308" styleClass="login-input" />
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <CheckBox text="Ghi nhớ đăng nhập" />
                </HBox>

                <Label fx:id="errorLabel" styleClass="login-error" text="" />

                <Button maxWidth="1.7976931348623157E308" onAction="#handleLogin" styleClass="login-btn" text="ĐĂNG NHẬP" />

                <HBox alignment="CENTER" spacing="6.0">
                    <Label styleClass="login-muted" text="Chưa có tài khoản?" />
                    <Hyperlink text="Đăng ký ngay" />
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>

