<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="1080.0" prefWidth="1920.0" styleClass="login-root" stylesheets="@styles/login.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.apitestapp.controllers.LoginController">
    <children>
        <VBox maxHeight="560.0" maxWidth="380.0" spacing="18.0" styleClass="login-card" StackPane.alignment="CENTER">
            <padding>
                <Insets bottom="30" left="30" right="30" top="30" />
            </padding>
            <children>
                <VBox alignment="CENTER" spacing="5.0">
                    <Label styleClass="login-title" text="ĐĂNG NHẬP" />
                    <Label styleClass="login-subtitle" text="Chào mừng bạn quay trở lại!" />
                </VBox>

                <VBox spacing="6.0">
                    <Label styleClass="login-label" text="Tên đăng nhập" />
                    <TextField fx:id="usernameField" promptText="Nhập tên đăng nhập" styleClass="login-input" />
                </VBox>

                <VBox spacing="6.0">
                    <Label styleClass="login-label" text="Mật khẩu" />
                    <PasswordField fx:id="passwordField" promptText="Nhập mật khẩu" styleClass="login-input" />
                </VBox>

                <VBox spacing="6.0">
                    <Label styleClass="login-label" text="Vai trò" />
                    <ComboBox fx:id="roleComboBox" maxWidth="1.7976931348623157E308" styleClass="login-input-combo" />
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <CheckBox styleClass="login-checkbox" text="Ghi nhớ đăng nhập" />
                </HBox>

                <Label fx:id="errorLabel" styleClass="login-error" text="" />

                <Button maxWidth="1.7976931348623157E308" onAction="#handleLogin" styleClass="login-btn" text="ĐĂNG NHẬP" />

                <HBox alignment="CENTER" spacing="6.0">
                    <Label styleClass="login-muted" text="Chưa có tài khoản?" />
                    <Hyperlink styleClass="login-link" text="Đăng ký ngay" />
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>
