<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.shape.Circle?>
<ScrollPane xmlns:fx="http://javafx.com/fxml/1" fitToHeight="true" fitToWidth="true" styleClass="main-scroll-pane"
            stylesheets="@../styles/styles.css" xmlns="http://javafx.com/javafx/26"
            fx:controller="com.example.apitestapp.controllers.ProfileController">
    <content>
        <VBox spacing="20.0" styleClass="root-container" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="20.0"/>
            </padding>
            <children>
                <Label styleClass="page-title" text="THÔNG TIN NGƯỜI DÙNG"/>

                <GridPane hgap="25.0" vgap="20.0" VBox.vgrow="ALWAYS">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="35.0"/>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="65.0"/>
                    </columnConstraints>
                    <rowConstraints>
                        <!-- Quan trọng: RowConstraints có vgrow="ALWAYS" -->
                        <RowConstraints minHeight="10.0" vgrow="ALWAYS"/>
                    </rowConstraints>
                    <children>
                        <!-- Cột trái: Avatar và thông tin cơ bản -->
                        <VBox spacing="20.0" GridPane.columnIndex="0" fillWidth="true" VBox.vgrow="ALWAYS">
                            <children>
                                <VBox alignment="TOP_CENTER" spacing="20.0" styleClass="card" VBox.vgrow="ALWAYS">
                                    <children>
                                        <StackPane styleClass="profile-avatar-container" maxHeight="90" maxWidth="90">
                                            <Circle radius="45.0">
                                                <fill>
                                                    <LinearGradient endX="1.0" endY="1.0">
                                                        <stops>
                                                            <Stop offset="0.0" color="#e0f2fe"/>
                                                            <Stop offset="1.0" color="#d1fae5"/>
                                                        </stops>
                                                    </LinearGradient>
                                                </fill>
                                            </Circle>
                                            <Label style="-fx-font-size: 38px; -fx-text-fill: linear-gradient(to bottom right, #2563eb, #10b981);"
                                                   text="👤"/>
                                        </StackPane>

                                        <VBox alignment="CENTER" spacing="5.0">
                                            <children>
                                                <Label fx:id="lblTenHienThiProfile" styleClass="profile-name"
                                                       text="Sơn"/>
                                                <Label fx:id="lblRoleProfile" styleClass="profile-role-tag"
                                                       text="Tester"/>
                                            </children>
                                        </VBox>

                                        <Separator prefWidth="200.0" style="-fx-opacity: 0.4;"/>

                                        <VBox spacing="15.0" styleClass="info-list" alignment="CENTER_LEFT">
                                            <HBox alignment="CENTER_LEFT" spacing="12.0">
                                                <Label styleClass="unicode-icon-blue" text="✉"/>
                                                <Label fx:id="lblEmailProfile" styleClass="text-small"
                                                       text="son.nguyen@example.com"/>
                                            </HBox>
                                            <HBox alignment="CENTER_LEFT" spacing="12.0">
                                                <Label styleClass="unicode-icon-green" text="🛡"/>
                                                <Label fx:id="lblIconRoleProfile" styleClass="text-small"
                                                       text="Vai trò: Tester"/>
                                            </HBox>
                                            <HBox alignment="CENTER_LEFT" spacing="12.0">
                                                <Label styleClass="unicode-icon-blue" text="📅"/>
                                                <Label fx:id="lblIconNgayThamGiaProfile" styleClass="text-small"
                                                       text="Tham gia: 01/01/2025"/>
                                            </HBox>
                                        </VBox>

                                        <!-- Thêm VBox trống để đẩy nội dung lên trên (optional) -->
                                        <VBox VBox.vgrow="ALWAYS"/>
                                    </children>
                                    <padding>
                                        <Insets bottom="30.0" left="25.0" right="25.0" top="30.0"/>
                                    </padding>
                                </VBox>
                            </children>
                        </VBox>

                        <!-- Cột phải: Thông tin chi tiết tài khoản -->
                        <VBox spacing="20.0" GridPane.columnIndex="1" fillWidth="true" VBox.vgrow="ALWAYS">
                            <children>
                                <VBox spacing="20.0" styleClass="card" VBox.vgrow="ALWAYS">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                                            <Label style="-fx-font-size: 18px; -fx-text-fill: linear-gradient(to right, #2563eb, #10b981);"
                                                   text="📋"/>
                                            <Label styleClass="section-header" text="Thông tin chi tiết tài khoản"/>
                                        </HBox>

                                        <VBox spacing="18.0" VBox.vgrow="ALWAYS">
                                            <children>
                                                <VBox spacing="6.0">
                                                    <Label styleClass="form-label" text="Tên hiển thị"/>
                                                    <TextField fx:id="txtTenHienThi" editable="false"
                                                               maxWidth="1.7976931348623157E308"
                                                               styleClass="form-input-readonly"/>
                                                </VBox>

                                                <VBox spacing="6.0">
                                                    <Label styleClass="form-label" text="Email địa chỉ"/>
                                                    <TextField fx:id="txtEmail" editable="false"
                                                               maxWidth="1.7976931348623157E308"
                                                               styleClass="form-input-readonly"/>
                                                </VBox>

                                                <VBox spacing="6.0">
                                                    <Label styleClass="form-label" text="Số điện thoại"/>
                                                    <TextField fx:id="txtSoDienThoai" editable="false"
                                                               promptText="Chưa cập nhật"
                                                               maxWidth="1.7976931348623157E308"
                                                               styleClass="form-input-readonly"/>
                                                </VBox>

                                                <VBox spacing="6.0">
                                                    <Label styleClass="form-label" text="Vai trò hệ thống"/>
                                                    <ComboBox fx:id="roleComboBox" disable="true"
                                                              maxWidth="1.7976931348623157E308"
                                                              promptText="Chọn vai trò"
                                                              styleClass="form-select-disabled"/>
                                                </VBox>
                                            </children>
                                        </VBox>
                                    </children>
                                    <padding>
                                        <Insets bottom="30.0" left="30.0" right="30.0" top="25.0"/>
                                    </padding>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </GridPane>
            </children>
        </VBox>
    </content>
</ScrollPane>