<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<ScrollPane fitToWidth="true" styleClass="main-scroll-pane" stylesheets="@../styles/styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.apitestapp.controllers.ProfileController">
    <content>
        <VBox spacing="20.0" styleClass="root-container">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="20.0" />
            </padding>
            <children>
                <Label styleClass="page-title" text="THÔNG TIN NGƯỜI DÙNG" />

                <GridPane hgap="20.0" vgap="20.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="35.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="65.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>

                        <VBox spacing="20.0" GridPane.columnIndex="0">
                            <children>
                                <VBox alignment="CENTER" spacing="10.0" styleClass="card">
                                    <children>
                                        <StackPane styleClass="profile-avatar-container">
                                            <Circle fill="#dbeafe" radius="45.0" />
                                            <Label text="👤" style="-fx-font-size: 40px; -fx-text-fill: #2563eb;" />
                                        </StackPane>
                                        <Label styleClass="profile-name" text="Sơn" />
                                        <Label styleClass="profile-role-tag" text="Tester" />

                                        <VBox spacing="8.0" styleClass="info-list">
                                            <HBox spacing="10.0" alignment="CENTER_LEFT">
                                                <Label text="✉" styleClass="unicode-icon" />
                                                <Label text="son.nguyen@example.com" styleClass="text-small"/>
                                            </HBox>
                                            <HBox spacing="10.0" alignment="CENTER_LEFT">
                                                <Label text="🛡" styleClass="unicode-icon" />
                                                <Label text="Vai trò: Tester" styleClass="text-small"/>
                                            </HBox>
                                            <HBox spacing="10.0" alignment="CENTER_LEFT">
                                                <Label text="📅" styleClass="unicode-icon" />
                                                <Label text="Tham gia: 01/01/2025" styleClass="text-small"/>
                                            </HBox>
                                        </VBox>
                                        <Button maxWidth="1.7976931348623157E308" styleClass="btn-primary" text="Chỉnh sửa hồ sơ" />
                                    </children>
                                    <padding>
                                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                                    </padding>
                                </VBox>

                                <VBox spacing="15.0" styleClass="card">
                                    <children>
                                        <HBox spacing="8.0" alignment="CENTER_LEFT">
                                            <Label text="📈" style="-fx-font-size: 16px;" />
                                            <Label styleClass="section-header" text="Thống kê hoạt động" />
                                        </HBox>
                                        <VBox spacing="10.0">
                                            <HBox styleClass="stat-item">
                                                <Label text="Tổng TC đã tạo" styleClass="stat-label"/>
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label text="45" styleClass="stat-value, text-blue"/>
                                            </HBox>
                                            <HBox styleClass="stat-item">
                                                <Label text="Tổng lần chạy" styleClass="stat-label"/>
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label text="128" styleClass="stat-value, text-green"/>
                                            </HBox>
                                            <HBox styleClass="stat-item">
                                                <Label text="Collection" styleClass="stat-label"/>
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label text="8" styleClass="stat-value, text-green"/>
                                            </HBox>
                                            <HBox styleClass="stat-item">
                                                <Label text="Tỉ lệ pass " styleClass="stat-label"/>
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label text="36%" styleClass="stat-value, text-green"/>
                                            </HBox>
                                            <HBox styleClass="stat-item">
                                                <Region HBox.hgrow="ALWAYS" />
                                            </HBox>
                                        </VBox>
                                    </children>
                                    <padding>
                                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                                    </padding>
                                </VBox>
                            </children>
                        </VBox>

                        <VBox spacing="20.0" GridPane.columnIndex="1">
                            <children>
                                <VBox spacing="15.0" styleClass="card">
                                    <children>
                                        <HBox spacing="8.0" alignment="CENTER_LEFT">
                                            <Label text="⚙" style="-fx-font-size: 16px;" />
                                            <Label styleClass="section-header" text="Cài đặt tài khoản" />
                                        </HBox>
                                        <GridPane vgap="15.0" hgap="15.0">
                                            <columnConstraints>
                                                <ColumnConstraints percentWidth="50" />
                                                <ColumnConstraints percentWidth="50" />
                                            </columnConstraints>
                                            <children>
                                                <VBox spacing="5.0" GridPane.columnIndex="0">
                                                    <Label text="Tên hiển thị" styleClass="form-label" />
                                                    <TextField text="Sơn" styleClass="form-input" />
                                                </VBox>
                                                <VBox spacing="5.0" GridPane.columnIndex="1">
                                                    <Label text="Email" styleClass="form-label" />
                                                    <TextField text="son.nguyen@example.com" styleClass="form-input" />
                                                </VBox>
                                                <VBox spacing="5.0" GridPane.rowIndex="1" GridPane.columnIndex="0">
                                                    <Label text="Số điện thoại" styleClass="form-label" />
                                                    <TextField promptText="Nhập số điện thoại" styleClass="form-input" />
                                                </VBox>
                                                <VBox spacing="5.0" GridPane.rowIndex="1" GridPane.columnIndex="1">
                                                    <Label text="Vai trò" styleClass="form-label" />
                                                    <ComboBox fx:id="roleComboBox" maxWidth="1.7976931348623157E308" styleClass="form-select" promptText="Chọn vai trò" />
                                                </VBox>
                                            </children>
                                        </GridPane>
                                        <HBox spacing="10.0">
                                            <Button styleClass="btn-primary" text="Lưu thay đổi" />
                                            <Button styleClass="btn-secondary" text="Hủy" />
                                        </HBox>
                                    </children>
                                    <padding>
                                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                                    </padding>
                                </VBox>



                                <VBox spacing="15.0" styleClass="card">
                                    <children>
                                        <HBox spacing="8.0" alignment="CENTER_LEFT">
                                            <Label text="🔒" style="-fx-font-size: 16px;" />
                                            <Label styleClass="section-header" text="Bảo mật" />
                                        </HBox>

                                        <VBox spacing="15.0">
                                            <children>
                                                <VBox spacing="5.0">
                                                    <Label text="Mật khẩu hiện tại" styleClass="form-label" />
                                                    <PasswordField promptText="Nhập mật khẩu hiện tại" styleClass="form-input" />
                                                </VBox>

                                                <VBox spacing="5.0">
                                                    <Label text="Mật khẩu mới" styleClass="form-label" />
                                                    <PasswordField promptText="Nhập mật khẩu mới" styleClass="form-input" />
                                                </VBox>

                                                <VBox spacing="5.0">
                                                    <Label text="Xác nhận mật khẩu mới" styleClass="form-label" />
                                                    <PasswordField promptText="Nhập lại mật khẩu mới" styleClass="form-input" />
                                                </VBox>

                                                <Button styleClass="btn-primary" text="Đổi mật khẩu" />
                                            </children>
                                        </VBox>
                                    </children>
                                    <padding>
                                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                                    </padding>
                                </VBox>

                                <VBox spacing="15.0" styleClass="card">
                                    <children>
                                        <HBox spacing="8.0" alignment="CENTER_LEFT">
                                            <Label text="🔔" style="-fx-font-size: 16px;" />
                                            <Label styleClass="section-header" text="Thông báo" />
                                        </HBox>

                                        <VBox spacing="20.0">
                                            <HBox alignment="CENTER_LEFT">
                                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                                    <Label text="Email khi test fail" style="-fx-font-weight: bold;" />
                                                    <Label text="Nhận email thông báo khi có test case fail" styleClass="text-small" />
                                                </VBox>
                                                <CheckBox selected="true" />
                                            </HBox>

                                            <HBox alignment="CENTER_LEFT">
                                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                                    <Label text="Email báo cáo hàng ngày" style="-fx-font-weight: bold;" />
                                                    <Label text="Nhận báo cáo tổng hợp mỗi ngày" styleClass="text-small" />
                                                </VBox>
                                                <CheckBox selected="true" />
                                            </HBox>

                                            <HBox alignment="CENTER_LEFT">
                                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                                    <Label text="Thông báo khi được assign TC" style="-fx-font-weight: bold;" />
                                                    <Label text="Nhận thông báo khi được giao testcase" styleClass="text-small" />
                                                </VBox>
                                                <CheckBox />
                                            </HBox>
                                        </VBox>
                                    </children>
                                    <padding>
                                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                                    </padding>
                                </VBox>



                                <VBox spacing="15.0" styleClass="card">
                                    <children>
                                        <Label styleClass="section-header" text="Hoạt động gần đây" />

                                        <VBox spacing="15.0">
                                            <VBox spacing="5.0">
                                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                                    <Circle radius="4.0" fill="#2563eb" /> <Label text="Chạy test suite &quot;Authentication&quot;" />
                                                </HBox>
                                                <Label text="2 giờ trước" styleClass="text-small" style="-fx-padding: 0 0 0 18;" />
                                            </VBox>

                                            <VBox spacing="5.0">
                                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                                    <Circle radius="4.0" fill="#10b981" /> <Label text="Tạo testcase mới &quot;TC08 - Get all departments&quot;" />
                                                </HBox>
                                                <Label text="5 giờ trước" styleClass="text-small" style="-fx-padding: 0 0 0 18;" />
                                            </VBox>

                                            <VBox spacing="5.0">
                                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                                    <Circle radius="4.0" fill="#b90e0e"/> <Label text="Cập nhật collection &quot;Customer API&quot;" />
                                                </HBox>
                                                <Label text="1 ngày trước" styleClass="text-small" style="-fx-padding: 0 0 0 18;" />
                                            </VBox>

                                            <VBox spacing="5.0">
                                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                                    <Circle radius="4.0" fill="#b9ac18"/> <Label text="Tạo environment  &quot;Staging&quot;" />
                                                </HBox>
                                                <Label text="2 ngày trước" styleClass="text-small" style="-fx-padding: 0 0 0 18;" />
                                            </VBox>

                                        </VBox>
                                    </children>
                                    <padding>
                                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                                    </padding>
                                </VBox>





                            </children>
                        </VBox>
                    </children>
                </GridPane>
            </children>
        </VBox>
    </content>
</ScrollPane>