<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml/1" prefHeight="800.0" prefWidth="1100.0" spacing="24.0" styleClass="content-area"
      stylesheets="@../styles/report.css" xmlns="http://javafx.com/javafx/17"
      fx:controller="com.example.apitestapp.controllers.ReportController">
    <children>
        <Label styleClass="page-title" text="BÁO CÁO CHI TIẾT"/>

        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <content>
                <VBox spacing="36.0" styleClass="section-bg">
                    <padding>
                        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
                    </padding>
                    <children>
                        <Label styleClass="section-title" text="NỘI DUNG BÁO CÁO CHI TIẾT"/>

                        <GridPane hgap="20.0" vgap="16.0"
                                  style="-fx-background-color: #f8fafc; -fx-padding: 24; -fx-background-radius: 16; -fx-border-color: #edf2f7; -fx-border-radius: 16;">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="33.0"/>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="33.0"/>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="34.0"/>
                            </columnConstraints>
                            <children>
                                <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <children>
                                        <Label styleClass="info-label" text="MÃ RUN"/>
                                        <Label fx:id="lblRunId" styleClass="info-value" text="-"/>
                                    </children>
                                </VBox>
                                <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <children>
                                        <Label styleClass="info-label" text="NGƯỜI CHẠY"/>
                                        <Label fx:id="lblRunner" styleClass="info-value" text="-"/>
                                    </children>
                                </VBox>
                                <VBox spacing="4.0" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                    <children>
                                        <Label styleClass="info-label" text="MÁY THỰC THI"/>
                                        <Label fx:id="lblMachine" styleClass="info-value" text="-"/>
                                    </children>
                                </VBox>
                                <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                    <children>
                                        <Label styleClass="info-label" text="HỆ ĐIỀU HÀNH"/>
                                        <Label fx:id="lblOS" styleClass="info-value" text="Windows 11"/>
                                    </children>
                                </VBox>
                                <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                    <children>
                                        <Label styleClass="info-label" text="THỜI GIAN"/>
                                        <Label fx:id="lblTime" styleClass="info-value" text="-"/>
                                    </children>
                                </VBox>
                                <VBox spacing="4.0" GridPane.columnIndex="2" GridPane.rowIndex="1">
                                    <children>
                                        <Label styleClass="info-label" text="KẾT QUẢ CHUNG"/>
                                        <Label fx:id="lblOverall"
                                               style="-fx-background-color: #fee2e2; -fx-text-fill: #ef4444; -fx-padding: 4 12; -fx-background-radius: 99; -fx-font-weight: bold; -fx-font-size: 11; -fx-border-color: #fca5a5; -fx-border-radius: 99;"
                                               text="-"/>
                                    </children>
                                </VBox>
                            </children>
                        </GridPane>

                        <HBox alignment="CENTER" prefHeight="100.0" spacing="40.0" styleClass="stat-box-container"
                              style="-fx-padding: 24 0;">
                            <children>
                                <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                                      style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 4 1 1 1; -fx-border-radius: 0 0 16 16; -fx-background-radius: 0 0 16 16; -fx-padding: 15; -fx-border-color: #6366f1 #e2e8f0 #e2e8f0 #e2e8f0;">
                                    <children>
                                        <Label styleClass="stat-label" text="Tổng số TestCase"/>
                                        <Label fx:id="lblTotal" styleClass="card-value" text="0"/>
                                    </children>
                                </VBox>
                                <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                                      style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 4 1 1 1; -fx-border-radius: 0 0 16 16; -fx-background-radius: 0 0 16 16; -fx-padding: 15; -fx-border-color: #10b981 #e2e8f0 #e2e8f0 #e2e8f0;">
                                    <children>
                                        <Label styleClass="stat-label" text="Vượt qua (Pass)"/>
                                        <Label fx:id="lblPass" styleClass="card-value" style="-fx-text-fill: #10b981;"
                                               text="0"/>
                                    </children>
                                </VBox>
                                <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                                      style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 4 1 1 1; -fx-border-radius: 0 0 16 16; -fx-background-radius: 0 0 16 16; -fx-padding: 15; -fx-border-color: #f43f5e #e2e8f0 #e2e8f0 #e2e8f0;">
                                    <children>
                                        <Label styleClass="stat-label" text="Thất bại (Fail)"/>
                                        <Label fx:id="lblFail" styleClass="card-value" style="-fx-text-fill: #f43f5e;"
                                               text="0"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox spacing="24.0">
                            <children>
                                <VBox alignment="TOP_CENTER" HBox.hgrow="ALWAYS" spacing="15.0"
                                      styleClass="chart-box-bg" style="-fx-padding: 20;">
                                    <children>
                                        <Label styleClass="chart-title" text="Biểu đồ tỷ lệ kết quả"
                                               alignment="TOP_LEFT" maxWidth="Infinity"/>
                                        <PieChart fx:id="pieChart" prefHeight="250.0"/>
                                    </children>
                                </VBox>
                                <VBox alignment="TOP_CENTER" HBox.hgrow="ALWAYS" spacing="15.0"
                                      styleClass="chart-box-bg" style="-fx-padding: 20;">
                                    <children>
                                        <Label styleClass="chart-title" text="Biểu đồ thời gian phản hồi (ms)"
                                               alignment="TOP_LEFT" maxWidth="Infinity"/>
                                        <BarChart fx:id="barChart" legendVisible="false" prefHeight="250.0">
                                            <xAxis>
                                                <CategoryAxis side="BOTTOM"/>
                                            </xAxis>
                                            <yAxis>
                                                <NumberAxis side="LEFT"/>
                                            </yAxis>
                                        </BarChart>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <VBox spacing="16.0">
                            <children>
                                <Label styleClass="chart-title" style="-fx-font-size: 15;"
                                       text="Chi tiết từng testcase"/>
                                <TableView fx:id="reportTable" prefHeight="320.0">
                                    <columns>
                                        <TableColumn fx:id="colTc" prefWidth="80.0" text="Mã TC"/>
                                        <TableColumn fx:id="colName" prefWidth="300.0" text="Tên testcase"/>
                                        <TableColumn fx:id="colStatus" prefWidth="120.0" text="Kết quả"/>
                                        <TableColumn fx:id="colTime" prefWidth="120.0" text="Thời gian"/>
                                        <TableColumn fx:id="colNote" prefWidth="400.0" text="Ghi chú lỗi / Chi tiết"/>
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
    </padding>
</VBox>