<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="900.0" prefWidth="1200.0" styleClass="content-area" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.apitestapp.controllers.DashboardController">
    <children>
        <VBox spacing="25.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <Label styleClass="page-title" text="DASHBOARD" />

                <GridPane hgap="20.0" vgap="10.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="100.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="100.0" prefHeight="100.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <VBox styleClass="card, card-blue">
                            <Label styleClass="card-label" text="Tổng TC" />
                            <Label styleClass="card-value" text="120" />
                        </VBox>
                        <VBox styleClass="card, card-purple" GridPane.columnIndex="1">
                            <Label styleClass="card-label" text="Tổng Run" />
                            <Label styleClass="card-value" text="36" />
                        </VBox>
                        <VBox styleClass="card, card-green" GridPane.columnIndex="2">
                            <Label styleClass="card-label" text="Pass" />
                            <Label styleClass="card-value" text="98" />
                        </VBox>
                        <VBox styleClass="card, card-red" GridPane.columnIndex="3">
                            <Label styleClass="card-label" text="Fail" />
                            <Label styleClass="card-value" text="22" />
                        </VBox>
                    </children>
                </GridPane>

                <VBox styleClass="section-bg" VBox.vgrow="NEVER">
                    <children>
                        <Label styleClass="section-title" text="BIỂU ĐỒ PASS / FAIL" />
                        <PieChart fx:id="passFailChart" labelsVisible="true" legendSide="BOTTOM" prefHeight="300.0" />
                    </children>
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                </VBox>

                <VBox styleClass="section-bg" VBox.vgrow="ALWAYS">
                    <children>
                        <Label styleClass="section-title" text="LỊCH SỬ CHẠY GẦN ĐÂY" />
                        <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colTime" prefWidth="150.0" text="Thời gian" />
                                <TableColumn fx:id="colUser" prefWidth="150.0" text="Người chạy" />
                                <TableColumn fx:id="colMachine" prefWidth="150.0" text="Máy chạy" />
                                <TableColumn fx:id="colResult" prefWidth="150.0" text="Kết quả" />
                                <TableColumn fx:id="colDetail" prefWidth="150.0" text="Chi tiết" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>