<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1"
            prefHeight="900.0"
            prefWidth="1280.0"
            styleClass="content-area"
            xmlns="http://javafx.com/javafx/20"
            stylesheets="@../styles/dashboard.css"
            fx:controller="com.example.apitestapp.controllers.DashboardController">

    <children>
        <!-- Tăng spacing tổng thể từ 24 lên 32 -->
        <VBox spacing="32.0"
              AnchorPane.bottomAnchor="20.0"
              AnchorPane.leftAnchor="24.0"
              AnchorPane.rightAnchor="24.0"
              AnchorPane.topAnchor="24.0">

            <children>
                <!-- Header -->
                <Label styleClass="page-title" text="📊 DASHBOARD"/>
                <Label styleClass="page-subtitle" text="Tổng quan hệ thống testing API"/>

                <!-- 4 Cards - tăng khoảng cách giữa các card -->
                <GridPane hgap="24.0" vgap="20.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="140.0" prefHeight="140.0"/>
                    </rowConstraints>

                    <children>
                        <AnchorPane styleClass="card, card-blue">
                            <VBox alignment="CENTER_LEFT" spacing="8.0" AnchorPane.leftAnchor="24.0"
                                  AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0">
                                <Label styleClass="card-label" text="🔬 TỔNG TC"/>
                                <Label fx:id="lblTotalTc" styleClass="card-value" text="18"/>
                            </VBox>
                            <Label styleClass="card-icon-text" text="🔬" AnchorPane.rightAnchor="20.0"
                                   AnchorPane.bottomAnchor="15.0"/>
                        </AnchorPane>

                        <AnchorPane styleClass="card, card-purple" GridPane.columnIndex="1">
                            <VBox alignment="CENTER_LEFT" spacing="8.0" AnchorPane.leftAnchor="24.0"
                                  AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0">
                                <Label styleClass="card-label" text="▶️ TỔNG RUN"/>
                                <Label fx:id="lblTotalRun" styleClass="card-value" text="2"/>
                            </VBox>
                            <Label styleClass="card-icon-text" text="▶️" AnchorPane.rightAnchor="20.0"
                                   AnchorPane.bottomAnchor="15.0"/>
                        </AnchorPane>

                        <AnchorPane styleClass="card, card-green" GridPane.columnIndex="2">
                            <VBox alignment="CENTER_LEFT" spacing="8.0" AnchorPane.leftAnchor="24.0"
                                  AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0">
                                <Label styleClass="card-label" text="✅ PASS"/>
                                <Label fx:id="lblTotalPass" styleClass="card-value" text="9"/>
                            </VBox>
                            <Label styleClass="card-icon-text" text="✅" AnchorPane.rightAnchor="20.0"
                                   AnchorPane.bottomAnchor="15.0"/>
                        </AnchorPane>

                        <AnchorPane styleClass="card, card-red" GridPane.columnIndex="3">
                            <VBox alignment="CENTER_LEFT" spacing="8.0" AnchorPane.leftAnchor="24.0"
                                  AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0">
                                <Label styleClass="card-label" text="❌ FAIL"/>
                                <Label fx:id="lblTotalFail" styleClass="card-value" text="9"/>
                            </VBox>
                            <Label styleClass="card-icon-text" text="❌" AnchorPane.rightAnchor="20.0"
                                   AnchorPane.bottomAnchor="15.0"/>
                        </AnchorPane>
                    </children>
                </GridPane>

                <!-- 2 CỘT: Biểu đồ + Lịch sử - tăng spacing giữa 2 cột -->
                <HBox spacing="32.0" VBox.vgrow="ALWAYS">
                    <children>
                        <!-- Cột trái: Biểu đồ -->
                        <VBox styleClass="section-bg" HBox.hgrow="ALWAYS" maxHeight="400.0">
                            <children>
                                <Label styleClass="section-title" text="📊 BIỂU ĐỒ PASS / FAIL"/>
                                <PieChart fx:id="passFailChart"
                                          labelsVisible="true"
                                          legendSide="BOTTOM"
                                          prefHeight="280.0"
                                          VBox.vgrow="ALWAYS"/>
                            </children>
                            <padding>
                                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0"/>
                            </padding>
                        </VBox>

                        <!-- Cột phải: Lịch sử chạy gần đây -->
                        <VBox styleClass="section-bg" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="section-title" text="🕐 LỊCH SỬ CHẠY GẦN ĐÂY"/>

                                <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colTime" prefWidth="155.0" minWidth="140.0"
                                                     text="⏰ THỜI GIAN"/>
                                        <TableColumn fx:id="colUser" prefWidth="115.0" minWidth="100.0"
                                                     text="👤 NGƯỜI CHẠY"/>
                                        <TableColumn fx:id="colMachine" prefWidth="175.0" minWidth="150.0"
                                                     text="💻 MÁY CHẠY"/>
                                        <TableColumn fx:id="colResult" prefWidth="125.0" minWidth="110.0"
                                                     text="📊 KẾT QUẢ"/>
                                        <TableColumn fx:id="colDetail" prefWidth="115.0" minWidth="100.0"
                                                     text="🔍 MÃ RUN"/>
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                    </columnResizePolicy>
                                    <placeholder>
                                        <Label text="Không có dữ liệu"
                                               style="-fx-text-fill: #94a3b8; -fx-padding: 20px;"/>
                                    </placeholder>
                                </TableView>
                            </children>
                            <padding>
                                <Insets bottom="16.0" left="16.0" right="16.0" top="16.0"/>
                            </padding>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>