<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="800.0" prefWidth="1000.0" spacing="25.0" styleClass="content-area" stylesheets="@../styles/styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.apitestapp.controllers.HistoryController">
    <children>
        <Label styleClass="page-title" text="LỊCH SỬ CHẠY" />

        <VBox spacing="20.0" styleClass="section-bg" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
            </padding>
            <children>
                <Label styleClass="section-title" text="NỘI DUNG LỊCH SỬ CHẠY" />

                <GridPane hgap="15.0" vgap="10.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="25.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="25.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="25.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="25.0" />
                    </columnConstraints>
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label styleClass="filter-label" text="Từ ngày" />
                                <DatePicker fx:id="dpFrom" maxWidth="1.7976931348623157E308" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0" GridPane.columnIndex="1">
                            <children>
                                <Label styleClass="filter-label" text="Đến ngày" />
                                <DatePicker fx:id="dpTo" maxWidth="1.7976931348623157E308" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0" GridPane.columnIndex="2">
                            <children>
                                <Label styleClass="filter-label" text="Kết quả" />
                                <ComboBox fx:id="cbResult" maxWidth="1.7976931348623157E308" promptText="Tất cả" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0" GridPane.columnIndex="3">
                            <children>
                                <Label styleClass="filter-label" text="Người chạy" />
                                <HBox spacing="8.0">
                                    <children>
                                        <TextField fx:id="txtSearch" promptText="Tìm kiếm..." HBox.hgrow="ALWAYS" />
                                        <Button mnemonicParsing="false" styleClass="btn-primary" text="⚡" textFill="WHITE" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </GridPane>

                <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="80.0" text="Mã run" />
                        <TableColumn fx:id="colTime" prefWidth="100.0" text="Thời gian" />
                        <TableColumn fx:id="colRunner" prefWidth="120.0" text="Người chạy" />
                        <TableColumn fx:id="colMachine" prefWidth="100.0" text="Máy chạy" />
                        <TableColumn fx:id="colOs" prefWidth="100.0" text="OS" />
                        <TableColumn fx:id="colMode" prefWidth="120.0" text="Chế độ" />
                        <TableColumn fx:id="colResult" prefWidth="100.0" text="Pass/Fail" />
                        <TableColumn fx:id="colStatus" prefWidth="80.0" text="KQ" />

                        <TableColumn fx:id="colDetails" prefWidth="60.0" style="-fx-alignment: CENTER;" text="CT" />
                        <TableColumn fx:id="colDelete" prefWidth="60.0" style="-fx-alignment: CENTER;" text="Xóa" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
</VBox>