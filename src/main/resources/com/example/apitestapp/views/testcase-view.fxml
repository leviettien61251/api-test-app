<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12.0" stylesheets="@../styles/styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.apitestapp.controllers.TestcaseController">
    <padding>
        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
    </padding>

    <children>
        <Label styleClass="page-title" text="Signup API Test (Viettel)" />

        <VBox spacing="10.0" styleClass="card">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Label text="Endpoint" />
                        <TextField fx:id="endpointField" HBox.hgrow="ALWAYS" />
                        <Label text="Timeout (s)" />
                        <TextField fx:id="timeoutField" prefWidth="80.0" />
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Label text="Phone key" />
                        <TextField fx:id="phoneKeyField" prefWidth="140.0" text="phonenumber" />
                        <Label text="Password key" />
                        <TextField fx:id="passwordKeyField" prefWidth="140.0" text="password" />
                        <Label text="Content-Type" />
                        <ComboBox fx:id="contentTypeCombo" prefWidth="220.0" />
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <ComboBox fx:id="testcasePicker" prefWidth="520.0" />
                        <Button onAction="#handleRunSelected" styleClass="btn-primary" text="Run Selected" />
                        <Button onAction="#handleRunAll" styleClass="btn-success" text="Run All" />
                        <Button onAction="#handleClearResults" styleClass="btn-outline" text="Clear Results" />
                    </children>
                </HBox>
            </children>
        </VBox>

        <VBox spacing="8.0" styleClass="card">
            <children>
                <Label text="Params (query) - format: key=value, moi dong 1 cap" />
                <TextArea fx:id="paramsArea" prefHeight="70.0" promptText="source=manual&#10;lang=vi" wrapText="true" />
                <Label text="Body (raw) - de trong neu muon dung data testcase tu dong" />
                <TextArea fx:id="bodyArea" prefHeight="110.0" promptText="{&#10;  &quot;phonenumber&quot;: &quot;098xxxxxxx&quot;,&#10;  &quot;password&quot;: &quot;Aa@12345&quot;&#10;}" wrapText="true" />
            </children>
        </VBox>

        <TableView fx:id="resultsTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="idColumn" prefWidth="58.0" text="#" />
                <TableColumn fx:id="caseColumn" prefWidth="350.0" text="Testcase" />
                <TableColumn fx:id="phoneColumn" prefWidth="130.0" text="Phone" />
                <TableColumn fx:id="expectedColumn" prefWidth="120.0" text="Expected" />
                <TableColumn fx:id="httpColumn" prefWidth="90.0" text="HTTP" />
                <TableColumn fx:id="verdictColumn" prefWidth="90.0" text="Result" />
                <TableColumn fx:id="messageColumn" prefWidth="410.0" text="Response / Note" />
            </columns>
        </TableView>

        <Label fx:id="summaryLabel" styleClass="text-muted" text="Ready." />

        <TextArea fx:id="logArea" editable="false" prefHeight="150.0" promptText="Execution log..." wrapText="true" />
    </children>
</VBox>
