<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<SplitPane xmlns:fx="http://javafx.com/fxml/1" dividerPositions="0.2, 0.75" prefHeight="750.0" prefWidth="1200.0"
           stylesheets="@../styles/styles.css" xmlns="http://javafx.com/javafx/17"
           fx:controller="com.example.apitestapp.controllers.TestcaseController">
    <items>

        <VBox spacing="10.0" styleClass="left-panel">
            <children>
                <VBox spacing="6.0">
                    <children>
                        <Label style="-fx-font-weight: bold;" text="Base URL"/>
                        <TextField fx:id="mainBaseUrlField" promptText="https://api.example.com"
                                   style="-fx-background-color: #ffffff; -fx-border-color: #ccc; -fx-border-radius: 3;"/>
                        <Button fx:id="saveRunBtn" maxWidth="Infinity"
                                style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold;"
                                text="Save Run"/>
                    </children>
                </VBox>

                <Separator prefWidth="200.0" />

                <Label styleClass="header-text" text="COLLECTIONS"/>
                <VBox spacing="6.0">
                    <children>
                        <Button fx:id="addTestSuiteBtn" maxWidth="Infinity" onAction="#handleAddTestSuite"
                                style="-fx-background-color: #27ae60; -fx-text-fill: white;"
                                text="+ Thêm testsuit"/>
                        <HBox spacing="6.0">
                            <children>
                                <Button fx:id="editTestSuiteBtn" maxWidth="Infinity" onAction="#handleEditTestSuite"
                                        style="-fx-background-color: #2980b9; -fx-text-fill: white;"
                                        text="Sửa" HBox.hgrow="ALWAYS"/>
                                <Button fx:id="deleteTestSuiteBtn" maxWidth="Infinity" onAction="#handleDeleteTestSuite"
                                        style="-fx-background-color: #e74c3c; -fx-text-fill: white;"
                                        text="Xóa" HBox.hgrow="ALWAYS"/>
                            </children>
                        </HBox>
                        <Button fx:id="editCleanupDataBtn" maxWidth="Infinity" onAction="#handleEditCleanupData"
                                style="-fx-background-color: #8e44ad; -fx-text-fill: white;"
                                text="Cleanup data"/>
                    </children>
                </VBox>
                <TreeView fx:id="testSuiteTree" showRoot="false" VBox.vgrow="ALWAYS"/>
            </children>
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
            </padding>
        </VBox>
        <ScrollPane fitToWidth="true">
            <content>
                <VBox spacing="15.0">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
                    </padding>
                    <children>
                        <VBox spacing="10.0" styleClass="card">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <Label fx:id="requestMethodLabel"
                                           style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-padding: 3 10; -fx-background-radius: 15;"
                                           text="POST">
                                        <font>
                                            <Font name="System Bold" size="12.0"/>
                                        </font>
                                    </Label>
                                    <TextField fx:id="baseUrlField" editable="false"
                                               style="-fx-background-color: #f1f2f6;"
                                               text="http://localhost:8080/api/v1/signup" HBox.hgrow="ALWAYS"/>
                                </HBox>
                                <Label style="-fx-font-weight: bold;" text="Headers"/>
                                <TextArea fx:id="headerTextArea" editable="true" prefHeight="70.0"
                                          promptText="Authorization: Bearer token&#10;X-Request-Id: test-001"
                                          style="-fx-font-family: 'Courier New'; -fx-control-inner-background: #f1f2f6;"
                                          wrapText="true"/>
                                <Label style="-fx-font-weight: bold;" text="Body (JSON)"/>
                                <TextArea fx:id="bodyTextArea" editable="true" prefHeight="80.0"
                                          style="-fx-font-family: 'Courier New'; -fx-control-inner-background: #2d3436; -fx-text-fill: #000;"
                                          text="{&#10;  &quot;phonenumber&quot;: &quot;098xxxxxxx&quot;,&#10;  &quot;password&quot;: &quot;Aa@12345&quot;&#10;}"/>
                            </children>
                        </VBox>

                        <VBox spacing="15.0" styleClass="card">
                            <children>
                                <Label style="-fx-font-size: 16px; -fx-font-weight: bold;"
                                       text="TEST SUITE: Signup API Test Suite"/>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <Button fx:id="runAllBtn" onAction="#handleRunAll"
                                            style="-fx-background-color: #27ae60; -fx-text-fill: white;"
                                            text="▶ Run All"/>
                                    <Button fx:id="runSelectedBtn" onAction="#handleRunSelected"
                                            style="-fx-background-color: #2980b9; -fx-text-fill: white;"
                                            text="▶ Run Selected"/>
                                    <Button fx:id="stopBtn" onAction="#handleStop" style="-fx-background-color: #e74c3c; -fx-text-fill: white;"
                                            text="■ Stop"/>
                                    <Button fx:id="addTestCaseBtn" onAction="#handleAddTestCase"
                                            style="-fx-background-color: #8e44ad; -fx-text-fill: white;"
                                            text="+ Thêm testcase"/>
                                    <Button fx:id="editTestCaseBtn" onAction="#handleEditTestCase"
                                            style="-fx-background-color: #7f8c8d; -fx-text-fill: white;"
                                            text="Sửa testcase"/>
                                    <Button fx:id="deleteTestCaseBtn" onAction="#handleDeleteTestCase"
                                            style="-fx-background-color: #c0392b; -fx-text-fill: white;"
                                            text="Xóa testcase"/>
                                    <ComboBox fx:id="executionModeCombo" prefWidth="150.0" promptText="Lần lượt"/>
                                    <ComboBox fx:id="stopConditionCombo" prefWidth="180.0" promptText="Chế độ dừng"/>
                                </HBox>

                                <TableView fx:id="testCaseTable" prefHeight="350.0">
                                    <columns>
                                        <TableColumn fx:id="colCheck" prefWidth="40.0" text="X" resizable="true" />
                                        <TableColumn fx:id="colName" prefWidth="250.0" text="Testcase" resizable="true"/>
                                        <TableColumn fx:id="colInput" prefWidth="270.0" text="Input" resizable="true"/>
                                        <TableColumn fx:id="colExpected" prefWidth="120.0" text="Mong đợi" resizable="true"/>
                                        <TableColumn fx:id="colStatus" prefWidth="80.0" text="HTTP" resizable="true"/>
                                        <TableColumn fx:id="colResult" prefWidth="100.0" text="Kết quả" resizable="true"/>
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>

        <VBox spacing="10.0" styleClass="right-panel">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
            </padding>
            <children>
                <Label style="-fx-font-weight: bold;" text="📋 KẾT QUẢ THỰC THI"/>
                <ListView fx:id="resultLogList" VBox.vgrow="ALWAYS"/>
                <VBox fx:id="summaryBox" spacing="5.0"
                      style="-fx-background-color: #f1f2f6; -fx-padding: 10; -fx-background-radius: 5;">
                    <children>
                        <Label style="-fx-font-weight: bold;" text="📊 TỔNG KẾT"/>
                        <Label fx:id="summaryText" text="Chưa có dữ liệu"/>
                    </children>
                </VBox>
                <Button fx:id="saveReportBtn" maxWidth="Infinity" onAction="#handleSaveReport" styleClass="btn-primary"
                        text="💾 Lưu báo cáo"/>
            </children>
        </VBox>
    </items>
</SplitPane>