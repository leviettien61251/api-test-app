<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="1080.0" prefWidth="1920.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.apitestapp.MainController">
    <left>
        <VBox maxWidth="420" minWidth="300" prefWidth="300" spacing="4" styleClass="sidebar">
            <padding>
                <Insets bottom="20" left="12" right="12" top="20" />
            </padding>

            <Button fx:id="btnCollections" maxWidth="Infinity" onAction="#navigateCollections" styleClass="nav-button" text="Collection" />

            <Button fx:id="btnEnvironments" maxWidth="Infinity" onAction="#navigateEnvironments" styleClass="nav-button" text="Environment" />

            <Button fx:id="btnHistory" maxWidth="Infinity" onAction="#navigateHistory" styleClass="nav-button" text="History" />
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentArea" prefHeight="150.0" prefWidth="200.0" BorderPane.alignment="CENTER" />
    </center>
    <top>
        <HBox minWidth="800.0" prefHeight="72.0" spacing="10.0" BorderPane.alignment="CENTER">
            <!-- Set a minimum width on the HBox -->
            <children>
                <Label fx:id="logo" alignment="BASELINE_CENTER" prefHeight="27.0" prefWidth="300.0" text="API Tester" textAlignment="CENTER">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
                <Button fx:id="btnDashboard" mnemonicParsing="false" onAction="#navigateDashboard" prefHeight="25.0" prefWidth="140.0" text="Dashboard" />
                <Button fx:id="btnTestcase" mnemonicParsing="false" onAction="#navigateTestcases" prefWidth="140.0" text="Testcase" />
                <Button fx:id="btnRequest" mnemonicParsing="false" onAction="#navigateRequests" prefWidth="140.0" text="Request" />
                <Button fx:id="btnReport" mnemonicParsing="false" onAction="#navigateReports" prefWidth="140.0" text="Report" />
            <HBox fillHeight="true" minWidth="0.0" prefHeight="100.0" prefWidth="800.0" HBox.hgrow="ALWAYS" />
                <Button fx:id="btnProfile" mnemonicParsing="false" onAction="#navigateProfile" prefHeight="25.0" prefWidth="165.0" text="Profile" HBox.hgrow="NEVER" />
            </children>
            <padding>
                <Insets left="10.0" right="10.0" top="24.0" />
            </padding>
        </HBox>
    </top>
</BorderPane>
