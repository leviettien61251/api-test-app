<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml/1" prefHeight="720.0" prefWidth="1280.0"
            xmlns="http://javafx.com/javafx/26" fx:controller="com.example.apitestapp.MainController">
    <fx:define>
        <ToggleGroup fx:id="sidebarGroup"/>
        <ToggleGroup fx:id="headerGroup"/>
    </fx:define>

    <left>
        <VBox minWidth="280.0" prefWidth="280.0" spacing="5" styleClass="sidebar">
            <padding>
                <Insets bottom="20" left="15" right="15" top="20"/>
            </padding>
            <children>
                <Label styleClass="logo-label" text=" 🔰 API Tester">
                    <VBox.margin>
                        <Insets bottom="30.0" left="10.0"/>
                    </VBox.margin>
                </Label>

                <ToggleButton fx:id="btnDashboard" onAction="#navigateDashboard" maxWidth="Infinity" selected="true"
                              styleClass="nav-item" text="📊 Dashboard" toggleGroup="$sidebarGroup"/>
                <ToggleButton fx:id="btnTestcase" onAction="#navigateTestcases" maxWidth="Infinity"
                              styleClass="nav-item"
                              text="🧪 Testcase" toggleGroup="$sidebarGroup"/>
                <ToggleButton fx:id="btnRequest" onAction="#navigateRequests" maxWidth="Infinity" styleClass="nav-item"
                              text="🚀 Request" toggleGroup="$sidebarGroup"/>
                <ToggleButton fx:id="btnReport" onAction="#navigateReports" styleClass="nav-item"
                              text="📈 Report" maxWidth="Infinity" toggleGroup="$sidebarGroup"/>
                <ToggleButton fx:id="btnHistory" maxWidth="Infinity" onAction="#navigateHistory" styleClass="nav-item"
                              text="⏳ History" toggleGroup="$sidebarGroup"/>
            </children>
        </VBox>
    </left>

    <center>
        <VBox>
            <children>
                <HBox alignment="CENTER_LEFT" minHeight="72.0" prefHeight="72.0" spacing="10.0" styleClass="header">
                    <children>

                        <HBox HBox.hgrow="ALWAYS"/>
                        <MenuButton fx:id="userMenuButton" styleClass="user-menu" text="👤 User">
                            <items>
                                <MenuItem onAction="#navigateProfile" text="👤 Thông tin cá nhân"/>
                                <MenuItem onAction="#handleLogout" text="⎋ Đăng xuất"/>
                            </items>
                        </MenuButton>
                    </children>
                    <padding>
                        <Insets left="20.0" right="20.0"/>
                    </padding>
                </HBox>

                <StackPane fx:id="contentArea" styleClass="content-area" VBox.vgrow="ALWAYS"/>
            </children>
        </VBox>
    </center>
</BorderPane>